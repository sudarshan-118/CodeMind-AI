# ─── CodeMind AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file with real secrets!

# Supabase project credentials (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clerk authentication (https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# Groq AI API key for deep semantic code analysis (https://console.groq.com)
VITE_GROQ_API_KEY=gsk_your-groq-api-key
